{
  "name": "iglebekk/generelle-laravel-prinsipper",
  "description": "Generelle Laravel-utviklingsprinsipper som publishable dokumentasjon.",
  "type": "library",
  "license": "proprietary",
  "keywords": [
    "laravel",
    "documentation",
    "principles",
    "coding-standards",
    "k2-grunderlab"
  ],
  "require": {
    "php": "^8.3",
    "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "laravel/pint": "^1.14",
    "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
    "pestphp/pest": "^2.0|^3.0|^4.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
  },
  "autoload": {
    "psr-4": {
      "Andersiglebekk\\LaravelPrinciples\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Andersiglebekk\\LaravelPrinciples\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "format": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Andersiglebekk\\LaravelPrinciples\\LaravelPrinciplesServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
